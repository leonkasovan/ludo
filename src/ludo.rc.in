#define RT_MANIFEST 24

#define IDI_APP_ICON 101

1 VERSIONINFO
 FILEVERSION @LUDO_VERSION_MAJOR@,@LUDO_VERSION_MINOR@,@LUDO_VERSION_PATCH@,@LUDO_VERSION_BUILD@
 PRODUCTVERSION @LUDO_VERSION_MAJOR@,@LUDO_VERSION_MINOR@,@LUDO_VERSION_PATCH@,@LUDO_VERSION_BUILD@
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 BEGIN
   BLOCK "StringFileInfo"
   BEGIN
     BLOCK "040904b0"
     BEGIN
       VALUE "CompanyName", "@LUDO_COMPANY@\0"
       VALUE "FileDescription", "@LUDO_DESCRIPTION@\0"
       VALUE "FileVersion", "@LUDO_VERSION_STR@\0"
       VALUE "ProductVersion", "@LUDO_VERSION_STR@\0"
     END
   END
   BLOCK "VarFileInfo"
   BEGIN
     VALUE "Translation", 0x0409, 1200
   END
 END

IDI_APP_ICON ICON "../res/icon/ludo.ico"

1 RT_MANIFEST "ludo.manifest"
