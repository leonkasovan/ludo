{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure",
      "type": "shell",
      "command": "cmake -G \"Ninja Multi-Config\" -B build-multi .",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: Build (Debug)",
      "type": "shell",
      "command": "cmake --build build-multi --config Debug --parallel",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "CMake: Build (Release)",
      "type": "shell",
      "command": "cmake --build build-multi --config Release --parallel",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Build (Configure + Debug)",
      "dependsOn": ["CMake: Configure", "CMake: Build (Debug)"],
      "runOptions": { "runOn": "default" }
    },
    {
      "label": "Build (Configure + Release)",
      "dependsOn": ["CMake: Configure", "CMake: Build (Release)"],
      "runOptions": { "runOn": "default" }
    }
  ]
}
