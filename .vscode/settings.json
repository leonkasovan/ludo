{
  "terminal.integrated.profiles.windows": {
    "w64devkit": {
      "path": "D:\\w64devkit\\bin\\sh.exe",
      "cwd": "${workspaceFolder}"
    },
    "MSYS2": {
      "path": "D:\\msys64\\usr\\bin\\bash.exe",
      "args": ["--login", "-i"],
      "env": {
        "MSYSTEM": "MINGW64",
        "CHERE_INVOKING": "1"
      },
      "icon": "terminal-bash",
      "cwd": "${workspaceFolder}"
    }
  },
  "terminal.integrated.defaultProfile.windows": "MSYS2"
}
